import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
        int x,y;
        Scanner scan= new Scanner(System.in);
        x=scan.nextInt();
        y=scan.nextInt();
        int a,b,c,d;
        a=x+y;
        b=x-y;
        c=x*y;
        d=x/y;
        System.out.println(a);
        System.out.println(b);
        System.out.println(c);
        System.out.println(d);
    }
}
